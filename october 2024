pipeline {
    agent any
    
    tools{
        maven "maven3.9.5"
    }// tools closing
    
    stages{
       
        stage('Git-checkout'){
            steps{
                git branch: 'development', credentialsId: '0b2cefa0-b2d0-4029-8840-49f65029a368', url: 'https://github.com/SharathOrganization/maven-web-application.git'
            }//steps closing
            
        } //stage closing
        
        stage ('Build'){
            steps{
                sh "mvn clean package"
            }//steps closing
            
        }//stage closing
        
        stage ('Sonarqube-Report'){
            steps{
                sh "mvn sonar:sonar"
            }//steps closing
                
            }//stage closing
        
        stage ('Nexus'){
            steps{
                sh "mvn deploy"
            }//steps closing
        }//stage closing
            
    }//stages closing

}// pipeline closing
